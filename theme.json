              "src": ["https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500&display=swap"]
            }
          ]
        }
      ]
    },
    "spacing": {
      "spacingSizes": [
        { "slug": "xs",  "size": "8px",  "name": "XS" },
        { "slug": "sm",  "size": "16px", "name": "SM" },
        { "slug": "md",  "size": "32px", "name": "MD" },
        { "slug": "lg",  "size": "64px", "name": "LG" },
        { "slug": "xl",  "size": "80px", "name": "XL" }
