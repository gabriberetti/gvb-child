{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "color": {
      "palette": [
        {
          "slug": "gvb-green",
          "color": "#459271",
          "name": "Green"
        },
        {
          "slug": "gvb-orange",
          "color": "#F28C3B",
          "name": "Orange"
        },
        {
          "slug": "gvb-orange-hover",
          "color": "#E65620",
          "name": "Orange Hover"
        },
        {
          "slug": "gvb-linen",
          "color": "#EDE8DB",
          "name": "Linen"
        },
        {
          "slug": "gvb-graphite",
          "color": "#2B2B2B",
          "name": "Graphite"
        },
        {
          "slug": "gvb-white",
          "color": "#FFFFFF",
          "name": "White"
        },
        {
          "slug": "gvb-black",
          "color": "#000000",
          "name": "Black"
        },
        {
          "slug": "gvb-divider",
          "color": "#E9E9E9",
          "name": "Divider"
        }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "slug": "scale-vf",
          "name": "Scale VF",
          "fontFamily": "'Scale VF', sans-serif",
          "fontFace": [
            {
              "fontFamily": "Scale VF",
              "fontStyle": "normal",
              "fontWeight": "400",
              "src": ["file:./assets/fonts/ScaleVF-Regular.woff2"]
            },
            {
              "fontFamily": "Scale VF",
              "fontStyle": "normal",
              "fontWeight": "700",
              "src": ["file:./assets/fonts/ScaleVF-Bold.woff2"]
            }
          ]
        }
      ],
      "fontSizes": [
        { "slug": "display", "size": "65px", "name": "Display" },
        { "slug": "h1",      "size": "60px", "name": "Heading 1" },
        { "slug": "h2",      "size": "40px", "name": "Heading 2" },
        { "slug": "h3",      "size": "32px", "name": "Heading 3" },
        { "slug": "h4",      "size": "24px", "name": "Heading 4" },
        { "slug": "h5",      "size": "18px", "name": "Heading 5" },
        { "slug": "h6",      "size": "30px", "name": "Heading 6" },
        { "slug": "body",    "size": "16px", "name": "Body" },
        { "slug": "label",   "size": "15px", "name": "Label" },
        { "slug": "label-sm","size": "12px", "name": "Label Small" }
      ]
    },
    "spacing": {
      "spacingSizes": [
        { "slug": "xs",  "size": "8px",   "name": "XS" },
        { "slug": "sm",  "size": "16px",  "name": "SM" },
        { "slug": "md",  "size": "32px",  "name": "MD" },
        { "slug": "lg",  "size": "64px",  "name": "LG" },
        { "slug": "xl",  "size": "80px",  "name": "XL" },
        { "slug": "xxl", "size": "100px", "name": "XXL" }
      ]
    },
    "layout": {
      "contentSize": "1200px",
      "wideSize": "1440px"
    }
  },
  "styles": {}
}
